            "out-max-auto": "0",
            "out-notify": "true",
            "out-ref": "\"POL-FR-0014\""
          },
          {
            "_id": "rule-large-medium-risk",
            "col-amount": "> 3000",
            "col-risk": "> 40",
            "col-age": "",
            "out-action": "\"review\"",
            "out-mfa": "true",
            "out-max-auto": "1000",
            "out-notify": "false",
            "out-ref": "\"POL-FR-0015\""
          },
          {
            "_id": "rule-medium-risk",
            "col-amount": "",
            "col-risk": "> 60",
            "col-age": "",
            "out-action": "\"review\"",
            "out-mfa": "true",
            "out-max-auto": "500",
            "out-notify": "false",
            "out-ref": "\"POL-FR-0016\""
