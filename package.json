{
  "name": "@timlavelle/iq-policy-decision-service",
  "version": "0.1.0",
  "private": true,
  "description": "Policy Decision Service — SVoP lookup, entitlement rules, disruption policy. Hosts sdk-core-policy.",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "pact:publish": "pact-broker publish ./pacts --broker-base-url $PACT_BROKER_BASE_URL"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-agent": "^3.1010.0",
    "@aws-sdk/client-bedrock-agent-runtime": "^3.1010.0",
    "@aws-sdk/client-s3": "^3.1010.0",
    "@gorules/zen-engine": "^0.53.0",
    "@upstash/redis": "^1.37.0",
    "@timlavelle/sdk-core-policy": "latest",
    "dotenv": "^17.3.1",
    "express": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@pact-foundation/pact": "latest",
    "@types/express": "latest",
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  }
}
